---
import { whatsappUrl, instagramUrl, endereco, telefone } from '../lib/categorias';

const googleMapsUrl = 'https://maps.app.goo.gl/McfFJd5H5pqictMb6';
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <!-- 15%: Logo -->
      <div class="footer__brand">
        <img src="/images/logo.svg" alt="Anacã Música" width="180" height="60" class="footer__logo" />
      </div>

      <!-- Fill: 3 caixas em grid -->
      <div class="footer__center">
        <div class="footer__col">
          <h4 class="footer__heading">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
            Faça uma visita!
          </h4>
          <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="footer__text-link">
            {endereco}
          </a>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Fale com a gente
          </h4>
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="footer__text-link">
            {telefone}
          </a>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">Nossas Redes</h4>
          <div class="footer__social-icons">
            <a href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="https://twitter.com/anacamusica" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
            </a>
            <a href="https://www.youtube.com/@anacamusica" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- 30%: Navegação -->
      <nav class="footer__nav">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/a-escola/">A Escola</a></li>
          <li>
            <a href="/cursos/">Cursos
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
            </a>
          </li>
          <li><a href="/professores/">Professores</a></li>
          <li><a href="/eventos/">Eventos</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer__bottom">
      <p>Copyright &copy; {new Date().getFullYear()} Anacã Artes – Todos os direitos reservados</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--space-xl) var(--space-lg);
  }

  /* 3-zone grid: logo 15% | center fill | nav 30% */
  .footer__top {
    display: grid;
    grid-template-columns: 15fr 100fr 30fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .footer__brand {
    display: flex;
    align-items: flex-start;
  }

  .footer__logo {
    height: 55px;
    width: auto;
  }

  /* Center zone: 3 boxes in sub-grid */
  .footer__center {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-lg);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer__heading svg {
    color: var(--color-text);
  }

  .footer__text-link {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .footer__text-link:hover {
    color: var(--color-accent);
  }

  .footer__social-icons {
    display: flex;
    gap: var(--space-sm);
  }

  .footer__social-icons a {
    color: var(--color-text);
    transition: color var(--transition);
  }

  .footer__social-icons a:hover {
    color: var(--color-accent);
  }

  /* Nav in 5th column */
  .footer__nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer__nav a {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 400;
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .footer__nav a:hover {
    color: var(--color-accent);
  }

  .footer__nav svg {
    opacity: 0.7;
  }

  /* Copyright */
  .footer__bottom {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    text-align: center;
    color: var(--color-text-muted);
    font-size: 13px;
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }

    .footer__brand {
      grid-column: 1 / -1;
    }

    .footer__center {
      grid-column: 1 / -1;
    }

    .footer__nav {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 767px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .footer__center {
      grid-template-columns: 1fr;
    }
  }
</style>
