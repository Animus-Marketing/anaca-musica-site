---
const images = Array.from({ length: 12 }, (_, i) =>
  `/images/estrutura/estrutura${String(i + 1).padStart(2, '0')}.webp`
);
const row1 = images.slice(0, 6);
const row2 = images.slice(6, 12);
---

<div class="marquee-section">
  <div class="marquee-row">
    <div class="marquee-track">
      {row1.map((src, i) => (
        <img src={src} alt={`Estrutura ${i + 1}`} loading="lazy" />
      ))}
      {row1.map((src, i) => (
        <img src={src} alt={`Estrutura ${i + 1}`} loading="lazy" aria-hidden="true" />
      ))}
    </div>
  </div>
  <div class="marquee-row">
    <div class="marquee-track marquee-track--reverse">
      {row2.map((src, i) => (
        <img src={src} alt={`Estrutura ${i + 7}`} loading="lazy" />
      ))}
      {row2.map((src, i) => (
        <img src={src} alt={`Estrutura ${i + 7}`} loading="lazy" aria-hidden="true" />
      ))}
    </div>
  </div>
</div>

<style>
  .marquee-section {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .marquee-row {
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    gap: 25px;
    width: max-content;
    animation: marquee-left 45s linear infinite;
  }

  .marquee-track--reverse {
    animation: marquee-right 45s linear infinite;
  }

  .marquee-track img {
    flex-shrink: 0;
    object-fit: cover;
    border-radius: 8px;
    max-height: 300px;
  }

  @keyframes marquee-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @media (max-width: 768px) {
    .marquee-track img {
      max-height: 200px;
    }
  }
</style>
