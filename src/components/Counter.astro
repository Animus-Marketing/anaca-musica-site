---
interface Props {
  target: number;
  suffix?: string;
  label: string;
}

const { target, suffix = '+', label } = Astro.props;
---

<div class="counter" data-target={target} data-suffix={suffix}>
  <span class="counter__value">0{suffix}</span>
  <span class="counter__label">{label}</span>
</div>

<style>
  .counter__value {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(42px, 4.5vw, 58px);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1em;
    letter-spacing: -0.04em;
    color: inherit;
    margin-bottom: 4px;
  }

  .counter__label {
    font-family: var(--font-body);
    font-size: 19px;
    font-weight: 400;
    line-height: 1.7em;
    color: inherit;
  }
</style>

<script>
  const counters = document.querySelectorAll('.counter');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const valueEl = el.querySelector('.counter__value');
      if (!valueEl || el.dataset.animated) return;

      el.dataset.animated = 'true';
      const target = Number(el.dataset.target);
      const suffix = el.dataset.suffix || '';
      const duration = 2000;
      const start = performance.now();

      function update(now: number) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * target);
        valueEl!.textContent = current.toLocaleString('pt-BR') + suffix;
        if (progress < 1) requestAnimationFrame(update);
      }

      requestAnimationFrame(update);
      observer.unobserve(el);
    });
  }, { threshold: 0.3 });

  counters.forEach(c => observer.observe(c));
</script>
